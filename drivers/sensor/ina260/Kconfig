config INA260
	bool "INA260 Current and Power Monitor"
	default y
	depends on DT_HAS_TI_INA260_ENABLED
	select I2C
	help
	  Enable driver for the INA260 Current and Power Monitor.

config INA260_FAKE
	bool "Use FFF to simulate communication with INA260 sensor"
	default n
	depends on INA260
	select TEST
	help
	  Replaces the read register operation with a function that
	  returns static data readings

if INA260_FAKE
config TEST_LOGGING_DEFAULTS
	default n
endif
